# Environment Variables for Travelobia
# Copy this file to .env and add your actual API keys

# OpenWeatherMap API Key
# Get your free API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# MongoDB Connection String
# For local MongoDB: mongodb://localhost:27017/travelobia
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/travelobia
MONGODB_URI=mongodb://localhost:27017/travelobia

# Server Port
PORT=3001
